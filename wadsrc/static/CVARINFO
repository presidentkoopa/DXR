server bool sv_wallcheck = true;

// --- Visual Fidelity (particle-count scaling) ---
// Referenced via CVar.GetCVar(...).GetInt() with no null-check in weaponflame.zs,
// weaponrlaunch.zs, vr_voxel_assembly.zs, and vr_rom_load.zs -- was never declared anywhere,
// so GetCVar returned null and the chained .GetInt() call would null-deref crash the instant
// any of those code paths ran (firing the flamethrower/rocket launcher, voxel assembly, or
// map load). 0-3 matches the "1 + fidelity" particle-count scaling already used at each site.
